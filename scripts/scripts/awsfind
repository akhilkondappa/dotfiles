#!/usr/bin/env bash

#######################################
# awsfind - Find and select AWS SSO profiles via fzf
#
# Usage:
#   awsfind              # Browse all SSO profiles
#   awsfind 978820379768 # Filter by account ID
#
# Outputs: assume <profile-name>
# Also copies to clipboard via pbcopy (macOS)
#######################################

set -euo pipefail

readonly AWS_CONFIG="${HOME}/.aws/config"
readonly FILTER="${1:-}"

# Parse active (uncommented) SSO profiles from ~/.aws/config
# Outputs: profile-name  (account-id)  role: role-name
parse_profiles() {
    awk '
    /^[[:space:]]*\[profile / {
        gsub(/^\[profile |\]$/, "")
        profile = $0
        account = ""; role = ""
        next
    }
    /^\[/ { profile = ""; next }
    /^;/ || /^$/ { next }
    profile && /^sso_account_id/ { split($0, a, "= *"); account = a[2] }
    profile && /^sso_role_name/  { split($0, a, "= *"); role = a[2] }
    profile && account && role {
        printf "%s  (%s)  role: %s\n", profile, account, role
        profile = ""; account = ""; role = ""
    }
    ' "$AWS_CONFIG"
}

profiles=$(parse_profiles)

if [[ -n "$FILTER" ]]; then
    profiles=$(echo "$profiles" | grep "$FILTER" || true)
fi

if [[ -z "$profiles" ]]; then
    echo "No profiles found" >&2
    exit 1
fi

selected=$(echo "$profiles" | fzf --height=40% --reverse --prompt="AWS Profile> " | awk '{print $1}')

if [[ -n "$selected" ]]; then
    cmd="assume ${selected}"
    echo "$cmd"
    echo -n "$cmd" | pbcopy
fi
